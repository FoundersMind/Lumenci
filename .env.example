# Copy to .env and fill in. Never commit real secrets.

# Required for chat / AI features
GROQ_API_KEY=

# Optional (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,your-app.onrender.com

# HTTPS origin(s) of your deployed site (comma-separated) — required for forms/CSRF behind TLS
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
