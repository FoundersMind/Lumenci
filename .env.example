# Copy to .env and fill in. Never commit real secrets.

# Required for chat / AI features
GROQ_API_KEY=

# Optional (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=0
# Comma-separated hostnames only (no https://). On Render you can omit this if RENDER_EXTERNAL_HOSTNAME is set (auto-added in settings).
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,lumenci.onrender.com

# Full https:// origins for CSRF (comma-separated). On Render, https://<your-host> is auto-added when RENDER_EXTERNAL_HOSTNAME is set.
DJANGO_CSRF_TRUSTED_ORIGINS=https://lumenci.onrender.com
